{
  "name": "openclaw-ot-qa",
  "version": "1.0.0",
  "description": "OT Cybersecurity QA Automation Suite",
  "type": "module",
  "scripts": {
    "plc": "tsx src/mock-plc/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "load": "k6 run src/load-tests/baseline.ts",
    "load:spike": "k6 run src/load-tests/spike.ts",
    "load:storm": "k6 run src/load-tests/write-storm.ts",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "report": "tsx src/reporter/index.ts",
    "dev": "vite src/ui",
    "build": "tsc && vite build src/ui"
  },
  "dependencies": {
    "express": "^4.18.2",
    "jsmodbus": "^4.0.10",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "axios": "^1.6.8",
    "cypress": "^13.10.0",
    "typescript": "^5.4.5",
    "tsx": "^4.11.0",
    "vite": "^5.2.11",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1"
  }
}
